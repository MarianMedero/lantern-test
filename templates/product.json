{
  "sections": {
    "main": {
      "type": "main-product",
      "blocks": {
        "title": {
          "type": "title",
          "settings": {}
        },
        "vendor": {
          "type": "text",
          "settings": {
            "text": "{{ product.vendor }}",
            "text_style": "body"
          }
        },
        "variant_picker": {
          "type": "variant_picker",
          "settings": {
            "picker_type": "button"
          }
        },
        "quantity_selector": {
          "type": "quantity_selector",
          "disabled": true,
          "settings": {}
        },
        "price": {
          "type": "price",
          "settings": {}
        },
        "buy_buttons": {
          "type": "buy_buttons",
          "settings": {
            "show_dynamic_checkout": true,
            "show_gift_card_recipient": false
          }
        },
        "description": {
          "type": "description",
          "settings": {}
        },
        "share": {
          "type": "share",
          "disabled": true,
          "settings": {
            "share_label": "Share"
          }
        }
      },
      "block_order": [
        "title",
        "vendor",
        "variant_picker",
        "quantity_selector",
        "price",
        "buy_buttons",
        "description",
        "share"
      ],
      "settings": {
        "enable_sticky_info": true,
        "media_size": "large",
        "constrain_to_viewport": true,
        "media_fit": "contain",
        "gallery_layout": "stacked",
        "media_position": "left",
        "image_zoom": "none",
        "mobile_thumbnails": "hide",
        "hide_variants": true,
        "enable_video_looping": false,
        "padding_top": 64,
        "padding_bottom": 0
      }
    },
    "product-specifications": {
      "type": "product-specifications",
      "blocks": {
        "board_type": {
          "type": "spec",
          "settings": {
            "metafield_key": "board_type"
          }
        },
        "length": {
          "type": "spec",
          "settings": {
            "metafield_key": "length"
          }
        },
        "flex_rating": {
          "type": "spec",
          "settings": {
            "metafield_key": "flex_rating"
          }
        },
        "profile": {
          "type": "spec",
          "settings": {
            "metafield_key": "profile"
          }
        },
        "core_material": {
          "type": "spec",
          "settings": {
            "metafield_key": "core_material"
          }
        },
        "base": {
          "type": "spec",
          "settings": {
            "metafield_key": "base"
          }
        },
        "skill_level": {
          "type": "spec",
          "settings": {
            "metafield_key": "skill_level"
          }
        },
        "terrain": {
          "type": "spec",
          "settings": {
            "metafield_key": "terrain"
          }
        }
      },
      "block_order": [
        "board_type",
        "length",
        "flex_rating",
        "profile",
        "core_material",
        "base",
        "skill_level",
        "terrain"
      ],
      "settings": {
        "eyebrow": "What's inside",
        "title": "The Complete Snowboard",
        "title_highlight": "Specs",
        "description": "Complete snowboard variants. Pre-tuned, waxed, and ready to ride.",
        "enable_debug_logs": true,
        "accent_color": "#8B2942",
        "background_color": "#F4F4F2",
        "card_background_color": "#FFFFFF",
        "padding_top": 64,
        "padding_bottom": 64
      }
    },
    "related-products": {
      "type": "related-products",
      "settings": {
        "heading": "Related products",
        "heading_size": "h2",
        "products_to_show": 4,
        "columns_desktop": 4,
        "color_scheme": "background-1",
        "image_ratio": "portrait",
        "show_secondary_image": true,
        "show_vendor": false,
        "show_rating": false,
        "columns_mobile": "2",
        "padding_top": 48,
        "padding_bottom": 28
      }
    }
  },
  "order": [
    "main",
    "product-specifications",
    "related-products"
  ]
}
