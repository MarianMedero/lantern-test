{{ 'section-product-specifications.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign metaobject = product.metafields[section.settings.metafield_namespace][section.settings.metafield_key].value
  assign has_visible_blocks = false

  for block in section.blocks
    assign field_key = block.settings.field_key
    assign field_values = blank

    if metaobject != blank and field_key != blank
      assign field_metafield = metaobject[field_key]
      if field_metafield != blank
        assign field_values = field_metafield.value
      endif
    endif

    if field_values != blank or request.design_mode
      assign has_visible_blocks = true
      break
    endif
  endfor
-%}

{%- if has_visible_blocks -%}
  {%- style -%}
    #ProductSpecifications-{{ section.id }} {
      --color-foreground: {{ settings.colors_text.red }}, {{ settings.colors_text.green }}, {{ settings.colors_text.blue }};
      --product-specs-accent: {{ section.settings.accent_color.red }}, {{ section.settings.accent_color.green }}, {{ section.settings.accent_color.blue }};
      --product-specs-bg: {{ section.settings.background_color.red }}, {{ section.settings.background_color.green }}, {{ section.settings.background_color.blue }};
      --product-specs-card-bg: {{ section.settings.card_background_color.red }}, {{ section.settings.card_background_color.green }}, {{ section.settings.card_background_color.blue }};
    }

    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
      padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
    }

    @media screen and (min-width: 750px) {
      .section-{{ section.id }}-padding {
        padding-top: {{ section.settings.padding_top }}px;
        padding-bottom: {{ section.settings.padding_bottom }}px;
      }
    }
  {%- endstyle -%}

  <section
    id="ProductSpecifications-{{ section.id }}"
    class="product-specifications section-{{ section.id }}-padding"
  >
    <div class="page-width">
      <div class="product-specifications__header">
        {%- if section.settings.eyebrow != blank -%}
          <div class="product-specifications__eyebrow">
            <p class="product-specifications__eyebrow-text">{{ section.settings.eyebrow | escape }}</p>
            <span class="product-specifications__eyebrow-line" aria-hidden="true"></span>
          </div>
        {%- endif -%}

        {%- if section.settings.title != blank or section.settings.title_highlight != blank -%}
          <h2 class="product-specifications__title">
            {%- if section.settings.title != blank -%}
              {{- section.settings.title | escape -}}
            {%- endif -%}
            {%- if section.settings.title_highlight != blank -%}
              <span class="product-specifications__title-highlight">
                {{- ' ' | append: section.settings.title_highlight | escape -}}
              </span>
            {%- endif -%}
          </h2>
        {%- endif -%}

        {%- if section.settings.description != blank -%}
          <p class="product-specifications__description">{{ section.settings.description | escape }}</p>
        {%- endif -%}
      </div>

      <ul class="product-specifications__grid" role="list">
        {%- for block in section.blocks -%}
          {%- liquid
            assign field_key = block.settings.field_key
            assign field_values = blank
            assign spec_value = blank

            if metaobject != blank and field_key != blank
              assign field_metafield = metaobject[field_key]
              if field_metafield != blank
                assign field_values = field_metafield.value
              endif
            endif

            if field_values != blank
              capture spec_value
                for item in field_values
                  unless forloop.first
                    echo ', '
                  endunless
                  echo item
                endfor
              endcapture
            endif
          -%}

          {%- if spec_value != blank or request.design_mode -%}
            <li
              class="product-specifications__card"
              {{ block.shopify_attributes }}
            >
              {%- if block.settings.label != blank -%}
                <h3 class="product-specifications__card-label">{{ block.settings.label | escape }}</h3>
              {%- endif -%}
              <p class="product-specifications__card-value">
                {%- if spec_value != blank -%}
                  {{- spec_value | escape -}}
                {%- elsif request.design_mode -%}
                  —
                {%- endif -%}
              </p>
            </li>
          {%- endif -%}
        {%- endfor -%}
      </ul>
    </div>
  </section>
{%- endif -%}

{% schema %}
{
  "name": "t:sections.product-specifications.name",
  "tag": "section",
  "class": "section",
  "enabled_on": {
    "templates": ["product"]
  },
  "settings": [
    {
      "type": "header",
      "content": "t:sections.product-specifications.settings.header_content.content"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "t:sections.product-specifications.settings.eyebrow.label",
      "default": "What's inside"
    },
    {
      "type": "text",
      "id": "title",
      "label": "t:sections.product-specifications.settings.title.label",
      "default": "The Complete Snowboard"
    },
    {
      "type": "text",
      "id": "title_highlight",
      "label": "t:sections.product-specifications.settings.title_highlight.label",
      "default": "Specs"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "t:sections.product-specifications.settings.description.label",
      "default": "Complete snowboard variants. Pre-tuned, waxed, and ready to ride."
    },
    {
      "type": "header",
      "content": "t:sections.product-specifications.settings.header_metafield.content"
    },
    {
      "type": "text",
      "id": "metafield_namespace",
      "label": "t:sections.product-specifications.settings.metafield_namespace.label",
      "default": "custom",
      "info": "t:sections.product-specifications.settings.metafield_namespace.info"
    },
    {
      "type": "text",
      "id": "metafield_key",
      "label": "t:sections.product-specifications.settings.metafield_key.label",
      "default": "specifications",
      "info": "t:sections.product-specifications.settings.metafield_key.info"
    },
    {
      "type": "header",
      "content": "t:sections.product-specifications.settings.header_colors.content"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "t:sections.product-specifications.settings.accent_color.label",
      "default": "#8B2942"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "t:sections.product-specifications.settings.background_color.label",
      "default": "#F4F4F2"
    },
    {
      "type": "color",
      "id": "card_background_color",
      "label": "t:sections.product-specifications.settings.card_background_color.label",
      "default": "#FFFFFF"
    },
    {
      "type": "header",
      "content": "t:sections.all.padding.section_padding_heading"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 64
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 64
    }
  ],
  "blocks": [
    {
      "type": "spec",
      "name": "t:sections.product-specifications.blocks.spec.name",
      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "t:sections.product-specifications.blocks.spec.settings.label.label",
          "default": "Spec label"
        },
        {
          "type": "text",
          "id": "field_key",
          "label": "t:sections.product-specifications.blocks.spec.settings.field_key.label",
          "info": "t:sections.product-specifications.blocks.spec.settings.field_key.info"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:sections.product-specifications.presets.name",
      "blocks": [
        {
          "type": "spec",
          "settings": {
            "label": "Board Type",
            "field_key": "board_type"
          }
        },
        {
          "type": "spec",
          "settings": {
            "label": "Length",
            "field_key": "length"
          }
        },
        {
          "type": "spec",
          "settings": {
            "label": "Flex Rating",
            "field_key": "flex_rating"
          }
        },
        {
          "type": "spec",
          "settings": {
            "label": "Profile",
            "field_key": "profile"
          }
        },
        {
          "type": "spec",
          "settings": {
            "label": "Core Material",
            "field_key": "core_material"
          }
        },
        {
          "type": "spec",
          "settings": {
            "label": "Base",
            "field_key": "base"
          }
        },
        {
          "type": "spec",
          "settings": {
            "label": "Skill Level",
            "field_key": "skill_level"
          }
        },
        {
          "type": "spec",
          "settings": {
            "label": "Terrain",
            "field_key": "terrain"
          }
        }
      ]
    }
  ]
}
{% endschema %}
